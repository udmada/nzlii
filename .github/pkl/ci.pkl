amends "@com.github.actions/Workflow.pkl"
import "@com.github.actions/Step.pkl"

import "common.pkl"

name = "CI"

on = "push"

jobs {
  ["check"] {
    `runs-on` = "ubuntu-slim"
    steps = (common.steps) {
      (Step) {
        name = "Verify pkl gen is up to date"
        run = "mise run pkl:gen && mise run fmt && git diff --exit-code .github/"
      }
      (Step) {
        name = "Type check"
        run = "mise run typecheck"
      }
      (Step) {
        name = "Lint"
        run = "mise run lint"
      }
      (Step) {
        name = "Format check"
        run = "mise run fmt:check"
      }
    }
  }
  ["test"] {
    `runs-on` = "ubuntu-slim"
    needs = "check"
    steps = (common.steps) {
      (Step) {
        name = "Test"
        run = "mise run test"
      }
    }
  }
}
